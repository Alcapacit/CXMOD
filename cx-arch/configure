#!/bin/sh
# CXMOD configure script
# Checks for required tools and writes config.mk

set -e

PREFIX=/usr/local
CC=gcc
VERBOSE=0

for arg in "$@"; do
    case "$arg" in
        --prefix=*)    PREFIX="${arg#*=}" ;;
        --cc=*)        CC="${arg#*=}" ;;
        --verbose)     VERBOSE=1 ;;
        --help|-h)
            echo "Usage: ./configure [options]"
            echo "  --prefix=DIR    Installation prefix (default: /usr/local)"
            echo "  --cc=COMPILER   C compiler to use (default: gcc)"
            echo "  --help          Show this help"
            exit 0
            ;;
    esac
done

log() { printf "  checking %-38s ... %s\n" "$1" "$2"; }
die() { echo "ERROR: $1" >&2; exit 1; }

echo ""
echo "CXMOD configure"
echo "==============="
echo ""

# C compiler
CC_FOUND=$(command -v "$CC" 2>/dev/null || command -v cc 2>/dev/null || echo "")
if [ -z "$CC_FOUND" ]; then
    die "C compiler not found. Install gcc: apt-get install gcc"
fi
CC=$(basename "$CC_FOUND")
log "C compiler" "$CC ($CC_FOUND)"

# C99 support
echo 'int main(void){return 0;}' > /tmp/cxmod_test.c
if ! "$CC_FOUND" -std=c99 -o /tmp/cxmod_test /tmp/cxmod_test.c 2>/dev/null; then
    die "C99 not supported by $CC"
fi
log "C99 standard" "OK"
rm -f /tmp/cxmod_test.c /tmp/cxmod_test

# GNU source
echo '#define _GNU_SOURCE
#include <stdio.h>
#include <sys/socket.h>
int main(void){return 0;}' > /tmp/cxmod_test.c
if "$CC_FOUND" -std=c99 -D_GNU_SOURCE -o /tmp/cxmod_test /tmp/cxmod_test.c 2>/dev/null; then
    log "_GNU_SOURCE" "OK"
else
    die "_GNU_SOURCE not available"
fi
rm -f /tmp/cxmod_test.c /tmp/cxmod_test

# /proc/net
for f in /proc/net/dev /proc/net/sockstat /proc/net/snmp; do
    if [ -r "$f" ]; then
        log "readable $f" "OK"
    else
        echo "  WARN: $f not readable (non-Linux or restricted container)" >&2
    fi
done

# /sys/class/net
if [ -d /sys/class/net ]; then
    log "/sys/class/net" "OK"
else
    echo "  WARN: /sys/class/net not found — some features limited" >&2
fi

# Optional: ethtool
ETHTOOL=$(command -v ethtool 2>/dev/null || echo "")
if [ -n "$ETHTOOL" ]; then
    log "ethtool (NIC offload)" "found ($ETHTOOL)"
else
    log "ethtool (NIC offload)" "NOT FOUND — install for offload commands"
fi

# Optional: tc
TC=$(command -v tc 2>/dev/null || echo "")
if [ -n "$TC" ]; then
    log "tc (QoS)" "found ($TC)"
else
    log "tc (QoS)" "NOT FOUND — install iproute2 for QoS commands"
fi

# Write Makefile config
cat > config.mk << CONFMK
# Generated by configure on $(date)
PREFIX  = $PREFIX
CC      = $CC_FOUND
CONFMK

echo ""
echo "Configuration:"
echo "  Prefix:     $PREFIX"
echo "  Compiler:   $CC_FOUND"
echo ""
echo "Build:"
echo "  make"
echo "  sudo make install"
echo ""
echo "Or just:  sudo cx fix     (after make)"
